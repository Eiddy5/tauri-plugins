{
  "productName": "Screen Capture Performance Lab",
  "version": "0.1.0",
  "identifier": "com.example.screen-capture-performance",
  "build": {
    "beforeDevCommand": "vite",
    "beforeBuildCommand": "vite build",
    "additionalWatchFolders": [
      "../../../src",
      "../../../Cargo.toml",
      "../../../build.rs"
    ],
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": false,
    "security": {
      "csp": null
    },
    "windows": [
      {
        "fullscreen": false,
        "height": 600,
        "resizable": true,
        "title": "Screen Capture Performance Lab",
        "width": 800
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
