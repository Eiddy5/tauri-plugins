{
  "productName": "tauri-app",
  "version": "0.1.0",
  "identifier": "com.eiddy.net-watcher-example",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "security": {
      "csp": null
    },
    "windows": [
      {
        "fullscreen": false,
        "height": 600,
        "resizable": true,
        "title": "tauri-app",
        "width": 800
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "net-watcher": {
      "autoStart": false,
      "targets": [
        { "id": "baidu", "url": "https://www.baidu.com" },
        {"id": "bing", "url": "https://www.bing.com/"}
      ],
      "intervalMs": 10000,
      "timeoutMs": 3000
    }
  }
}
